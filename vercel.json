{
  "version": 2,
  "routes": [
    {
      "src": "/public/images/(.*)",
      "dest": "/html/digitalize/assets/$1",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/html/digitalize/index.html"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
